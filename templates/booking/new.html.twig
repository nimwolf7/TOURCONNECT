{% extends 'base.html.twig' %}

{% block title %}New Booking | Tour Connect{% endblock %}

{% block body %}
<div class="admin-page">
    <div class="container mt-4">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header text-white d-flex justify-content-between align-items-center" style="background-color: #0E4A52;">
                <h4 class="mb-0">🆕 Create New Booking</h4>
                <a href="{{ path('app_booking_index') }}" class="btn btn-light btn-sm">
                    ← Back to List
                </a>
            </div>

            <div class="card-body" style="background-color: #F5F1E6;">
                {{ include('booking/_form.html.twig', {'button_label': 'Save Booking'}) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
