{% extends 'base.html.twig' %}

{% block title %}Edit Booking | Tour Connect{% endblock %}

{% block body %}
<style>
    .form-card {
        background: #F5F1E6;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .form-header {
        background: linear-gradient(135deg, #13616C, #0E4A52);
        color: white;
        padding: 25px 30px;
        border-bottom: 3px solid rgba(255,255,255,0.2);
    }

    .form-header h3 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-header h3 i {
        font-size: 1.3rem;
    }

    .form-body {
        padding: 35px 30px;
        background: #F5F1E6;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .form-group label {
        font-weight: 600;
        color: #0E4A52;
        margin-bottom: 8px;
        display: block;
        font-size: 14px;
    }

    .form-control {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 15px;
        transition: all 0.3s ease;
        background: #F5F1E6;
    }

    .form-control:focus {
        border-color: #13616C;
        background: #F5F1E6;
        box-shadow: 0 0 0 3px rgba(19,97,108,0.1);
        outline: none;
    }

    .form-select {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 12px 16px;
        font-size: 15px;
        transition: all 0.3s ease;
        background: #F5F1E6;
    }

    .form-select:focus {
        border-color: #13616C;
        background: #F5F1E6;
        box-shadow: 0 0 0 3px rgba(19,97,108,0.1);
        outline: none;
    }

    .button-group {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 30px;
        padding-top: 25px;
        border-top: 2px solid #d0cbb8;
    }

    .back-btn {
        background: rgba(108,117,125,0.1);
        border: 2px solid #6c757d;
        color: #6c757d;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

    .back-btn:hover {
        background: #6c757d;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(108,117,125,0.3);
    }

    .update-btn {
        background: linear-gradient(135deg, #13616C, #0E4A52);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(19,97,108,0.3);
    }

    .update-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(19,97,108,0.4);
    }

    .delete-section {
        display: flex;
        justify-content: flex-end;
        margin-top: 12px;
    }

    .delete-btn {
        background: linear-gradient(135deg, #dc3545, #c82333);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(220,53,69,0.3);
    }

    .delete-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(220,53,69,0.4);
    }

    .delete-btn:active,
    .update-btn:active,
    .back-btn:active {
        transform: translateY(0);
    }
</style>

<div class="admin-page">
    <div class="container mt-4">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}
        <div class="form-card">
            <div class="form-header">
                <h3>
                    <i class="fa-solid fa-pen-to-square"></i>
                    Edit Booking
                </h3>
            </div>

            <div class="form-body">
                {{ form_start(form) }}
                    <div class="form-group">
                        {{ form_label(form.quantity) }}
                        {{ form_widget(form.quantity, {'attr': {'class': 'form-control', 'placeholder': 'Enter quantity'}}) }}
                        {{ form_errors(form.quantity) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.status) }}
                        {{ form_widget(form.status, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(form.status) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.bookingDate) }}
                        {{ form_widget(form.bookingDate, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.bookingDate) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.totalAmount) }}
                        {{ form_widget(form.totalAmount, {'attr': {'class': 'form-control', 'placeholder': 'Enter total amount'}}) }}
                        {{ form_errors(form.totalAmount) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.user) }}
                        {{ form_widget(form.user, {'attr': {'class': 'form-select'}}) }}
                        {{ form_errors(form.user) }}
                    </div>

                    <div class="button-group">
                        <a href="{{ path('app_booking_index') }}" class="back-btn">
                            <i class="fa-solid fa-arrow-left"></i>
                            Back to List
                        </a>

                        <button type="submit" class="update-btn">
                            <i class="fa-solid fa-floppy-disk"></i>
                            Update Booking
                        </button>
                    </div>
                {{ form_end(form) }}

                <div class="delete-section">
                    <form method="post" action="{{ path('app_booking_delete', {'id': booking.id}) }}"
                          onsubmit="return confirm('Are you sure you want to delete this booking?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ booking.id) }}">
                        <button type="submit" class="delete-btn">
                            <i class="fa-solid fa-trash"></i>
                            Delete Booking
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}