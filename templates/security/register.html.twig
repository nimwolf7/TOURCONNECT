<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Tour Connect</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: url('{{ asset('images/ph.jpg') }}') center/cover no-repeat;
            position: relative;
        }
        
        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(14, 74, 82, 0.5) 0%, rgba(26, 95, 104, 0.4) 100%);
            z-index: 1;
        }
        
        .register-container {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 480px;
            padding: 20px;
        }
        
        .register-card {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 24px;
            padding: 45px 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            backdrop-filter: blur(10px);
        }
        
        .register-header {
            text-align: center;
            margin-bottom: 35px;
        }
        
        .register-logo {
            width: 100px;
            height: 100px;
            margin: 0 auto 20px;
            background: linear-gradient(135deg, #0E4A52 0%, #1a5f68 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 24px rgba(14, 74, 82, 0.3);
        }
        
        .register-logo i {
            font-size: 45px;
            color: white;
        }
        
        .register-header h1 {
            font-size: 30px;
            font-weight: 700;
            color: #0E4A52;
            margin-bottom: 8px;
        }
        
        .register-header p {
            color: #6b7280;
            font-size: 14px;
            font-weight: 400;
        }
        
        .alert {
            padding: 14px 18px;
            border-radius: 12px;
            margin-bottom: 20px;
            font-size: 14px;
            font-weight: 500;
            animation: slideDown 0.3s ease-out;
        }
        
        .alert-danger {
            background: linear-gradient(135deg, #fee2e2 0%, #fecaca 100%);
            color: #dc2626;
            border-left: 4px solid #dc2626;
        }
        
        .alert ul {
            margin: 0;
            padding-left: 20px;
        }
        
        .alert li {
            margin: 5px 0;
        }
        
        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .form-group {
            margin-bottom: 22px;
        }
        
        .form-group label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 8px;
        }
        
        .input-wrapper {
            position: relative;
        }
        
        .input-wrapper i {
            position: absolute;
            left: 18px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: 16px;
            z-index: 1;
        }
        
        .form-control {
            width: 100%;
            padding: 14px 20px 14px 50px;
            border: 2px solid #e5e7eb;
            border-radius: 12px;
            font-size: 15px;
            font-family: 'Poppins', sans-serif;
            transition: all 0.3s ease;
            background: #f9fafb;
        }
        
        .form-control:focus {
            outline: none;
            border-color: #0E4A52;
            background: #F5F1E6;
            box-shadow: 0 0 0 4px rgba(14, 74, 82, 0.1);
        }
        
        .password-strength {
            font-size: 12px;
            margin-top: 5px;
            color: #6b7280;
        }
        
        .terms-wrapper {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 16px;
            background: #f9fafb;
            border-radius: 12px;
            border: 2px solid #e5e7eb;
            transition: all 0.3s ease;
        }
        
        .terms-wrapper:has(.terms-checkbox:checked) {
            background: #ecfdf5;
            border-color: #10b981;
        }
        
        .terms-checkbox {
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: #0E4A52;
            margin-top: 2px;
            flex-shrink: 0;
        }
        
        .terms-label {
            font-size: 13px;
            color: #374151;
            line-height: 1.6;
            margin: 0;
            font-weight: 400;
            cursor: pointer;
        }
        
        .terms-link {
            color: #0E4A52;
            font-weight: 600;
            text-decoration: underline;
        }
        
        .terms-link:hover {
            color: #1a5f68;
        }
        
        .btn-register {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, #0E4A52 0%, #1a5f68 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
            font-family: 'Poppins', sans-serif;
            box-shadow: 0 4px 12px rgba(14, 74, 82, 0.3);
        }
        
        .btn-register:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(14, 74, 82, 0.4);
        }
        
        .btn-register:active {
            transform: translateY(0);
        }
        
        .btn-register i {
            margin-left: 8px;
        }
        
        .register-footer {
            text-align: center;
            margin-top: 25px;
            padding-top: 25px;
            border-top: 2px solid #e5e7eb;
        }
        
        .register-footer p {
            color: #6b7280;
            font-size: 14px;
        }
        
        .register-footer a {
            color: #0E4A52;
            font-weight: 600;
            text-decoration: underline;
        }
        
        .register-footer a:hover {
            color: #1a5f68;
        }
        
        @media (max-width: 480px) {
            .register-card {
                padding: 40px 30px;
            }
            
            .register-header h1 {
                font-size: 26px;
            }
            
            .register-logo {
                width: 90px;
                height: 90px;
            }
            
            .register-logo i {
                font-size: 38px;
            }
        }
    </style>
</head>
<body>
    <div class="register-container">
        <div class="register-card">
            <div class="register-header">
                <div class="register-logo">
                    <i class="fas fa-user-plus"></i>
                </div>
                <h1>Create Account</h1>
                <p>Join Tour Connect today</p>
            </div>
            
            {% if errors is not empty %}
                <div class="alert alert-danger">
                    <ul>
                        {% for error in errors %}
                            <li><i class="fas fa-exclamation-circle"></i> {{ error }}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            <form method="post">
                <div class="form-group">
                    <label for="inputUsername">
                        Username
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-user"></i>
                        <input 
                            type="text" 
                            value="{{ username }}" 
                            name="username" 
                            id="inputUsername" 
                            class="form-control" 
                            placeholder="Choose a username"
                            autocomplete="username" 
                            required 
                            autofocus
                            minlength="3"
                        >
                    </div>
                </div>
                
                <div class="form-group">
                    <label for="inputPassword">
                        Password
                    </label>
                    <div class="input-wrapper">
                        <i class="fas fa-lock"></i>
                        <input 
                            type="password" 
                            name="password" 
                            id="inputPassword" 
                            class="form-control" 
                            placeholder="Create a strong password"
                            autocomplete="new-password" 
                            required
                            minlength="6"
                        >
                    </div>
                </div>
                
                <div class="form-group">
                    <div class="terms-wrapper">
                        <input 
                            type="checkbox" 
                            name="agree_terms" 
                            id="agreeTerms" 
                            class="terms-checkbox"
                            required
                        >
                        <label for="agreeTerms" class="terms-label">
                            I agree to the <a href="#" class="terms-link">Terms and Conditions</a> and <a href="#" class="terms-link">Privacy Policy</a>
                        </label>
                    </div>
                </div>
                
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">

                <button class="btn-register" type="submit">
                    Create Account
                    <i class="fas fa-arrow-right"></i>
                </button>
            </form>
            
            <div class="register-footer">
                <p>Already have an account? <a href="{{ path('app_login') }}">Sign In</a></p>
            </div>
        </div>
    </div>
</body>
</html>
