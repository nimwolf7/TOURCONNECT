{% extends 'base.html.twig' %}

{% block title %}Edit User | Tour Connect{% endblock %}

{% block body %}
<style>
    .form-card {
        background: #F5F1E6;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        max-width: 600px;
        margin: 0 auto;
    }

    .form-header {
        background: linear-gradient(135deg, #13616C, #0E4A52);
        color: white;
        padding: 25px 30px;
        border-radius: 15px 15px 0 0;
    }

    .form-body {
        padding: 30px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        margin-bottom: 8px;
        color: #0E4A52;
    }

    .form-control {
        width: 100%;
        padding: 12px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 15px;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        border-color: #13616C;
        outline: none;
        box-shadow: 0 0 0 3px rgba(19,97,108,0.1);
    }

    .checkbox-group {
        display: flex;
        gap: 20px;
        margin-top: 10px;
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
    }

    .checkbox-label input {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .btn-group {
        display: flex;
        gap: 10px;
        margin-top: 30px;
    }

    .btn {
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 600;
        text-decoration: none;
        border: none;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background: linear-gradient(135deg, #13616C, #0E4A52);
        color: white;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(19,97,108,0.3);
    }

    .btn-secondary {
        background: #6c757d;
        color: white;
    }

    .btn-secondary:hover {
        background: #5a6268;
    }

    .help-text {
        font-size: 13px;
        color: #6c757d;
        margin-top: 5px;
    }
</style>

<div class="form-card">
    <div class="form-header">
        <h3><i class="fas fa-user-edit"></i> Edit User: {{ user.username }}</h3>
    </div>

    <div class="form-body">
        <form method="post">
            <div class="form-group">
                <label class="form-label" for="username">
                    <i class="fas fa-user"></i> Username
                </label>
                <input type="text" id="username" name="username" class="form-control" value="{{ user.username }}" required>
            </div>

            <div class="form-group">
                <label class="form-label" for="password">
                    <i class="fas fa-lock"></i> Password
                </label>
                <input type="password" id="password" name="password" class="form-control" placeholder="Leave blank to keep current password">
                <div class="help-text">Leave empty to keep the current password</div>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="fas fa-user-shield"></i> Roles
                </label>
                <div class="checkbox-group">
                    <label class="checkbox-label">
                        <input type="checkbox" name="roles[]" value="ROLE_ADMIN" 
                               {% if 'ROLE_ADMIN' in user.roles %}checked{% endif %}>
                        <span>Admin</span>
                    </label>
                    <label class="checkbox-label">
                        <input type="checkbox" name="roles[]" value="ROLE_STAFF"
                               {% if 'ROLE_STAFF' in user.roles %}checked{% endif %}>
                        <span>Staff</span>
                    </label>
                </div>
            </div>

            <div class="btn-group">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save"></i> Update User
                </button>
                <a href="{{ path('app_user_index') }}" class="btn btn-secondary">
                    <i class="fas fa-times"></i> Cancel
                </a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
