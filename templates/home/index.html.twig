{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Work+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #123640;
            --reef: #0e6b73;
            --sand: #f6efe3;
            --clay: #d57a5c;
            --mist: #e7f0ef;
            --shadow: 0 20px 40px rgba(18, 54, 64, 0.12);
        }

        .content-area {
            padding: 0;
            background: var(--sand);
        }

        .landing {
            font-family: 'Work Sans', Arial, sans-serif;
            color: var(--ink);
        }

        .landing h1,
        .landing h2,
        .landing h3 {
            font-family: 'Playfair Display', 'Times New Roman', serif;
            letter-spacing: 0.2px;
        }

        .landing a {
            text-decoration: none;
        }

        .landing .container-wide {
            width: min(1200px, 92vw);
            margin: 0 auto;
        }

        .landing-nav {
            position: sticky;
            top: 0;
            z-index: 20;
            background: rgba(246, 239, 227, 0.92);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(18, 54, 64, 0.08);
        }

        .landing-nav-inner {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 0;
        }

        .brand-mark {
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 600;
            color: var(--ink);
        }

        .brand-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: var(--clay);
            box-shadow: 0 0 0 6px rgba(213, 122, 92, 0.15);
        }

        .nav-links {
            display: flex;
            gap: 20px;
            font-size: 15px;
            color: var(--ink);
        }

        .nav-links a {
            color: var(--ink);
            font-weight: 500;
        }

        .nav-cta {
            padding: 10px 18px;
            background: var(--ink);
            color: #fff;
            border-radius: 999px;
            font-size: 14px;
            font-weight: 600;
            transition: transform 0.2s ease;
        }

        .nav-cta:hover {
            transform: translateY(-2px);
        }

        .nav-cta-group {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-cta.secondary {
            background: transparent;
            color: var(--ink);
            border: 1px solid rgba(18, 54, 64, 0.35);
        }

        .hero {
            background: linear-gradient(120deg, rgba(18, 54, 64, 0.85), rgba(14, 107, 115, 0.75)), url('{{ asset('images/ph.jpg') }}');
            background-size: cover;
            background-position: center;
            color: #fff;
            padding: 120px 0 90px;
        }

        .hero-grid {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            gap: 28px;
            align-items: center;
        }

        .hero-copy {
            grid-column: span 7;
        }

        .hero-title {
            font-size: clamp(2.6rem, 4vw, 4.2rem);
            margin-bottom: 18px;
        }

        .hero-sub {
            font-size: 1.1rem;
            line-height: 1.6;
            margin-bottom: 28px;
            max-width: 560px;
        }

        .hero-actions {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
        }

        .btn-primary,
        .btn-ghost {
            padding: 12px 22px;
            border-radius: 999px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-primary {
            background: var(--clay);
            color: #fff;
        }

        .btn-ghost {
            border: 1px solid rgba(255, 255, 255, 0.6);
            color: #fff;
        }

        .hero-card {
            grid-column: span 5;
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 24px;
            border-radius: 22px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(6px);
        }

        .hero-card h3 {
            margin-bottom: 12px;
            font-size: 1.4rem;
        }

        .hero-card ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .hero-card li {
            display: flex;
            gap: 10px;
            align-items: flex-start;
            margin-bottom: 12px;
            font-size: 0.98rem;
        }

        .hero-card i {
            color: #fff;
        }

        .stats {
            background: var(--mist);
            padding: 40px 0;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            text-align: center;
        }

        .stat-number {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--reef);
        }

        .section {
            padding: 80px 0;
        }

        .section-title {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 20px;
            margin-bottom: 36px;
        }

        .section-title p {
            max-width: 520px;
            margin: 0;
            color: rgba(18, 54, 64, 0.75);
        }

        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 22px;
        }

        .card {
            background: #fff;
            padding: 24px;
            border-radius: 20px;
            box-shadow: var(--shadow);
            border: 1px solid rgba(18, 54, 64, 0.06);
        }

        .card h3 {
            font-size: 1.2rem;
            margin-bottom: 10px;
        }

        .highlight-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 24px;
        }

        .highlight {
            background: linear-gradient(140deg, #ffffff 0%, #f9f6f0 100%);
            border-radius: 24px;
            padding: 28px;
            border: 1px solid rgba(213, 122, 92, 0.2);
        }

        .highlight span {
            color: var(--clay);
            font-weight: 600;
            font-size: 0.9rem;
        }

        .testimonials {
            background: #0e4a52;
            color: #fff;
        }

        .testimonials .section-title h2 {
            color: #f6efe3;
        }

        .testimonials .section-title p {
            color: rgba(246, 239, 227, 0.85);
        }

        .testimonials .testimonial-card h3 {
            color: #ffe7d6;
        }

        .testimonials .testimonial-card p {
            color: rgba(246, 239, 227, 0.9);
        }

        .testimonials .testimonial-card strong {
            color: #ffffff;
        }

        .testimonial-card {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }

        .pricing {
            background: var(--mist);
        }

        .price-tag {
            font-size: 2rem;
            color: var(--reef);
            margin: 10px 0 18px;
        }

        .faq-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 18px;
        }

        .cta {
            padding: 70px 0 90px;
            background: linear-gradient(120deg, #123640 0%, #0e6b73 100%);
            color: #fff;
            text-align: center;
        }

        .cta h2 {
            margin-bottom: 14px;
        }

        .cta p {
            max-width: 620px;
            margin: 0 auto 28px;
        }

        @media (max-width: 900px) {
            .hero-grid {
                grid-template-columns: 1fr;
            }

            .hero-copy,
            .hero-card {
                grid-column: span 1;
            }

            .landing-nav-inner {
                flex-wrap: wrap;
                gap: 12px;
            }

            .nav-links {
                width: 100%;
                flex-wrap: wrap;
            }
        }

        @media (max-width: 600px) {
            .hero {
                padding: 90px 0 70px;
            }

            .section {
                padding: 60px 0;
            }

            .section-title {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
{% endblock %}

{% block body %}
    <div class="landing">
        <nav class="landing-nav">
            <div class="container-wide landing-nav-inner">
                <div class="brand-mark">
                    <span class="brand-dot"></span>
                    <span>Tour Connect</span>
                </div>
                <div class="nav-links">
                    <a href="#journeys">Journeys</a>
                    <a href="#experience">Experience</a>
                    <a href="#stories">Stories</a>
                    <a href="#plans">Plans</a>
                    <a href="{{ path('app_about') }}">About Us</a>
                    <a href="{{ path('app_contact') }}">Contact Us</a>
                </div>
                <div class="nav-cta-group">
                    <a class="nav-cta secondary" href="{{ path('app_register') }}">Register</a>
                    <a class="nav-cta" href="{{ path('app_login') }}">Login</a>
                </div>
            </div>
        </nav>

        <section class="hero">
            <div class="container-wide hero-grid">
                <div class="hero-copy">
                    <p style="text-transform: uppercase; letter-spacing: 2px; font-size: 0.85rem;">Curated Philippine escapes, made easy</p>
                    <h1 class="hero-title">Plan a trip that feels made just for you.</h1>
                    <p class="hero-sub">Share your style, your dates, and your dream stops. We personalize the route, book fast, and stay with you the whole way.</p>
                    <div class="hero-actions">
                        <a class="btn-primary" href="{{ path('app_register') }}">
                            <i class="fa-solid fa-map-location-dot"></i>
                            Register
                        </a>
                        <a class="btn-ghost" href="#journeys">
                            <i class="fa-solid fa-compass"></i>
                            Explore journeys
                        </a>
                    </div>
                </div>
                <div class="hero-card">
                    <h3>How we take care of you</h3>
                    <ul>
                        <li><i class="fa-solid fa-circle-check"></i>Personalized itineraries built around your pace.</li>
                        <li><i class="fa-solid fa-circle-check"></i>Fast booking with clear, transparent pricing.</li>
                        <li><i class="fa-solid fa-circle-check"></i>Local partners you can trust at every stop.</li>
                        <li><i class="fa-solid fa-circle-check"></i>Friendly support before, during, and after your trip.</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="stats">
            <div class="container-wide stats-grid">
                <div>
                    <div class="stat-number">120+</div>
                    <div>Personalized itineraries</div>
                </div>
                <div>
                    <div class="stat-number">48 hrs</div>
                    <div>Average planning time</div>
                </div>
                <div>
                    <div class="stat-number">4.9/5</div>
                    <div>Traveler satisfaction</div>
                </div>
                <div>
                    <div class="stat-number">24/7</div>
                    <div>On-trip support</div>
                </div>
            </div>
        </section>

        <section class="section" id="journeys">
            <div class="container-wide">
                <div class="section-title">
                    <h2>Journeys shaped around your pace</h2>
                    <p>Blend coastlines, culture, and quiet moments with a plan that feels balanced and unhurried.</p>
                </div>
                <div class="card-grid">
                    <div class="card">
                        <h3>Island days, gently paced</h3>
                        <p>Move between coves, reefs, and sunset dinners with transfers handled for you.</p>
                    </div>
                    <div class="card">
                        <h3>City and highland balance</h3>
                        <p>Pair cool mornings in the mountains with lively food walks and market visits.</p>
                    </div>
                    <div class="card">
                        <h3>Slow stays that feel local</h3>
                        <p>Settle into handpicked homes and meet makers who know the neighborhood best.</p>
                    </div>
                    <div class="card">
                        <h3>Team retreats that flow</h3>
                        <p>We handle logistics, wellness, and bonding so your team can simply show up.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="section" id="experience">
            <div class="container-wide">
                <div class="section-title">
                    <h2>Travel with less planning stress</h2>
                    <p>We remove the back-and-forth so you can focus on the moments that matter.</p>
                </div>
                <div class="highlight-grid">
                    <div class="highlight">
                        <span>Share</span>
                        <h3>Your style, your rhythm</h3>
                        <p>Tell us what you love and we shape a route with buffers, weather checks, and thoughtful options.</p>
                    </div>
                    <div class="highlight">
                        <span>Book</span>
                        <h3>Fast, clear reservations</h3>
                        <p>We handle stays, guides, and transport in one timeline with pricing you can trust.</p>
                    </div>
                    <div class="highlight">
                        <span>Travel</span>
                        <h3>Support that stays close</h3>
                        <p>Get real-time updates and friendly help while you travel, right inside your portal.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="section testimonials" id="stories">
            <div class="container-wide">
                <div class="section-title">
                    <h2>Traveler stories</h2>
                    <p>Warm reviews from travelers who wanted a trip that felt personal and cared for.</p>
                </div>
                <div class="card-grid">
                    <div class="card testimonial-card">
                        <h3>"Every detail felt thoughtful."</h3>
                        <p>We planned a multi-city honeymoon in a few days. Transfers were ready and the pacing was perfect.</p>
                        <p><strong>Marielle P.</strong> · Cebu</p>
                    </div>
                    <div class="card testimonial-card">
                        <h3>"The support felt like a friend."</h3>
                        <p>A storm changed our ferry schedule and the team rerouted everything within minutes.</p>
                        <p><strong>Jonas M.</strong> · Manila</p>
                    </div>
                    <div class="card testimonial-card">
                        <h3>"Our team retreat just flowed."</h3>
                        <p>Logistics for 40 people were smooth, so we focused on bonding and strategy.</p>
                        <p><strong>Andrea S.</strong> · Davao</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="section pricing" id="plans">
            <div class="container-wide">
                <div class="section-title">
                    <h2>Plans built for every traveler</h2>
                    <p>Choose a plan that matches your pace today and upgrade as your trip grows.</p>
                </div>
                <div class="card-grid">
                    <div class="card">
                        <h3>Essential</h3>
                        <div class="price-tag">PHP 3,500</div>
                        <p>Great for weekend escapes and simple routes.</p>
                        <p>Includes 1 itinerary, 2 bookings, and email support.</p>
                    </div>
                    <div class="card">
                        <h3>Signature</h3>
                        <div class="price-tag">PHP 6,800</div>
                        <p>Our favorite for multi-stop getaways.</p>
                        <p>Includes 3 itineraries, unlimited bookings, and live chat support.</p>
                    </div>
                    <div class="card">
                        <h3>Enterprise</h3>
                        <div class="price-tag">Custom</div>
                        <p>Tailored for teams, retreats, and company travel.</p>
                        <p>Dedicated coordinator, reporting, and 24/7 coverage.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="section">
            <div class="container-wide">
                <div class="section-title">
                    <h2>Frequently asked questions</h2>
                    <p>Quick answers to help you plan with ease.</p>
                </div>
                <div class="faq-grid">
                    <div class="card">
                        <h3>How fast can we build a trip?</h3>
                        <p>Most itineraries are ready within 48 hours after your consult.</p>
                    </div>
                    <div class="card">
                        <h3>Can I customize everything?</h3>
                        <p>Yes. You can swap hotels, guides, and activities before booking.</p>
                    </div>
                    <div class="card">
                        <h3>Do you offer group discounts?</h3>
                        <p>We apply discounts for groups of 10+ and returning teams.</p>
                    </div>
                    <div class="card">
                        <h3>What if my dates change?</h3>
                        <p>We monitor changes and send options quickly, without extra fees.</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="cta">
            <div class="container-wide">
                <h2>Ready to plan a trip that feels easy?</h2>
                <p>Tell us your style, your group, and your dream destination. We will handle the details from there.</p>
                <a class="btn-primary" href="{{ path('app_register') }}">
                    <i class="fa-solid fa-plane-departure"></i>
                    Build my trip
                </a>
            </div>
        </section>
    </div>
{% endblock %}
