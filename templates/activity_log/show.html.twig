{% extends 'base.html.twig' %}

{% block title %}Activity Log{% endblock %}

{% block body %}
    <h1>Activity Log Details</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ activity_log.id }}</td>
            </tr>
            <tr>
                <th>Action</th>
                <td>{{ activity_log.action }}</td>
            </tr>
            <tr>
                <th>Timestamp</th>
                <td>{{ activity_log.timestamp ? activity_log.timestamp|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>IpAddress</th>
                <td>{{ activity_log.ipAddress }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_activity_log_index') }}">back to list</a>

    <a href="{{ path('app_activity_log_edit', {'id': activity_log.id}) }}">edit</a>

    {{ include('activity_log/_delete_form.html.twig') }}
{% endblock %}
