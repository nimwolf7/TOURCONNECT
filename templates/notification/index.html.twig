{% extends 'base.html.twig' %}

{% block title %}Notifications{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Notification Management</h2>
        <a href="{{ path('app_notification_new') }}" class="btn btn-primary">
            <i class="fa-solid fa-plus me-2"></i> Create New
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Message</th>
                        <th scope="col">Type</th>
                        <th scope="col">Status</th>
                        <th scope="col">Date Sent</th>
                        <th scope="col" class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for notification in notifications %}
                        <tr>
                            <td>{{ notification.id }}</td>
                            <td>{{ notification.message }}</td>
                            <td>{{ notification.type }}</td>
                            <td>
                                {% if notification.status == 'Sent' %}
                                    <span class="badge bg-success">{{ notification.status }}</span>
                                {% elseif notification.status == 'Pending' %}
                                    <span class="badge bg-warning text-dark">{{ notification.status }}</span>
                                {% else %}
                                    <span class="badge bg-secondary">{{ notification.status }}</span>
                                {% endif %}
                            </td>
                            <td>{{ notification.dateSent ? notification.dateSent|date('Y-m-d H:i:s') : '' }}</td>
                            <td class="text-center">
                                <a href="{{ path('app_notification_show', {'id': notification.id}) }}" class="btn btn-sm btn-info text-white">
                                    <i class="fa-solid fa-eye"></i> Show
                                </a>
                                <a href="{{ path('app_notification_edit', {'id': notification.id}) }}" class="btn btn-sm btn-warning text-white">
                                    <i class="fa-solid fa-pen-to-square"></i> Edit
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No records found.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
h2 {
    color: #0E4A52;
}
.table th {
    background-color: #0E4A52 !important;
    color: #fff !important;
}
.table-hover tbody tr:hover {
    background-color: #f8f9fa;
}
.card {
    border-radius: 12px;
}
</style>
{% endblock %}
