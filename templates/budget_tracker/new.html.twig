{% extends 'base.html.twig' %}

{% block title %}New Budget Tracker | Tour Connect{% endblock %}

{% block body %}
<style>
    .form-card {
        background: #F5F1E6;
        border-radius: 15px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .form-header {
        background: linear-gradient(135deg, #13616C, #0E4A52);
        color: white;
        padding: 25px 30px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 3px solid rgba(255,255,255,0.2);
    }

    .form-header h3 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-header h3 i {
        font-size: 1.3rem;
    }

    .back-btn-header {
        background: rgba(255,255,255,0.2);
        border: 1px solid rgba(255,255,255,0.3);
        color: white;
        padding: 8px 16px;
        border-radius: 8px;
        text-decoration: none;
        font-size: 14px;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
    }

    .back-btn-header:hover {
        background: rgba(255,255,255,0.3);
        color: white;
        transform: translateX(-3px);
    }

    .form-body {
        padding: 35px 30px;
        background: #f8f9fa;
    }

    .alert {
        border-radius: 10px;
        padding: 15px 20px;
        margin-bottom: 20px;
        border: none;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    }

    .alert-success {
        background: linear-gradient(135deg, #d4edda, #c3e6cb);
        color: #155724;
    }

    .alert-danger {
        background: linear-gradient(135deg, #f8d7da, #f5c6cb);
        color: #721c24;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .form-label {
        display: block;
        font-weight: 600;
        color: #0E4A52;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .form-control,
    .form-select {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        font-size: 15px;
        transition: all 0.3s ease;
        background: #F5F1E6;
    }

    .form-control:focus,
    .form-select:focus {
        outline: none;
        border-color: #13616C;
        box-shadow: 0 0 0 3px rgba(19,97,108,0.1);
    }

    .form-control::placeholder {
        color: #999;
    }

    .form-errors {
        color: #dc3545;
        font-size: 13px;
        margin-top: 5px;
        display: block;
    }

    .button-group {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        padding-top: 25px;
        border-top: 2px solid #e0e0e0;
        margin-top: 10px;
    }

    .back-btn {
        background: #F5F1E6;
        color: #0E4A52;
        border: 2px solid #0E4A52;
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
    }

    .back-btn:hover {
        background: #0E4A52;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(14,74,82,0.3);
    }

    .save-btn {
        background: linear-gradient(135deg, #28a745, #218838);
        color: white;
        border: none;
        padding: 12px 28px;
        border-radius: 10px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 12px rgba(40,167,69,0.3);
    }

    .save-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 16px rgba(40,167,69,0.4);
    }

    .save-btn:active,
    .back-btn:active {
        transform: translateY(0);
    }

    .save-btn i,
    .back-btn i {
        font-size: 14px;
    }
</style>

<div class="admin-page">
<div class="container mt-4">

    <!-- Flash Messages -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="form-card">
        <div class="form-header">
            <h3>
                <i class="fa-solid fa-plus-circle"></i>
                Create New Budget Tracker
            </h3>
            <a href="{{ path('app_budget_tracker_index') }}" class="back-btn-header">
                <i class="fa-solid fa-arrow-left"></i>
                Back to List
            </a>
        </div>

        <div class="form-body">
            {{ form_start(form) }}
            
            {{ include('budget_tracker/_form.html.twig') }}

            <div class="button-group">
                <a href="{{ path('app_budget_tracker_index') }}" class="back-btn">
                    <i class="fa-solid fa-arrow-left"></i>
                    Back to List
                </a>
                
                <button type="submit" class="save-btn">
                    <i class="fa-solid fa-save"></i>
                    Save Budget
                </button>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>
</div>
{% endblock %}