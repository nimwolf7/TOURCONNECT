<div class="mb-3">
    {{ form_label(form.booking, 'Booking', {'label_attr': {'class': 'form-label fw-bold'}}) }}
    {{ form_widget(form.booking, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.booking) }}
    <small class="text-muted">Customer/user and spent amount will be automatically taken from the selected booking.</small>
</div>

<div class="mb-3">
    {{ form_label(form.category, 'Category', {'label_attr': {'class': 'form-label fw-bold'}}) }}
    {{ form_widget(form.category, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.category) }}
</div>

<div class="mb-3">
    {{ form_label(form.amountPlanned, 'Planned Amount', {'label_attr': {'class': 'form-label fw-bold'}}) }}
    {{ form_widget(form.amountPlanned, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.amountPlanned) }}
</div>

<div class="mb-3">
    {{ form_label(form.amountSpent, 'Spent Amount', {'label_attr': {'class': 'form-label fw-bold'}}) }}
    {{ form_widget(form.amountSpent, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.amountSpent) }}
</div>

<div class="mb-3">
    {{ form_label(form.dateRange, 'Date Range', {'label_attr': {'class': 'form-label fw-bold'}}) }}
    {{ form_widget(form.dateRange, {'attr': {'class': 'form-control'}}) }}
    {{ form_errors(form.dateRange) }}
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const bookingField = document.getElementById('{{ form.booking.vars.id }}');
        const amountSpentField = document.getElementById('{{ form.amountSpent.vars.id }}');
        const bookingAmountMap = {{ booking_amount_map|default({})|json_encode|raw }};

        if (!bookingField || !amountSpentField) {
            return;
        }

        const applyBookingAmount = () => {
            const bookingId = bookingField.value;
            if (!bookingId || !(bookingId in bookingAmountMap)) {
                return;
            }

            amountSpentField.value = bookingAmountMap[bookingId];
        };

        applyBookingAmount();
        bookingField.addEventListener('change', applyBookingAmount);
    });
</script>