{{ form_start(form) }}
<div class="row g-3">
    <!-- Title -->
    <div class="col-md-6">
        <label class="form-label fw-semibold">Title</label>
        {{ form_widget(form.title, {'attr': {'class': 'form-control shadow-sm rounded'}}) }}
        {{ form_errors(form.title) }}
    </div>

    <!-- Price -->
    <div class="col-md-6">
        <label class="form-label fw-semibold">Price (PHP)</label>
        {{ form_widget(form.price, {'attr': {'class': 'form-control shadow-sm rounded', 'step': '0.01'}}) }}
        {{ form_errors(form.price) }}
    </div>

    <!-- Description -->
    <div class="col-12">
        <label class="form-label fw-semibold">Description</label>
        {{ form_widget(form.description, {'attr': {'class': 'form-control shadow-sm rounded', 'rows': 4}}) }}
        {{ form_errors(form.description) }}
    </div>

    <!-- Category -->
    <div class="col-md-6">
        <label class="form-label fw-semibold">Category</label>
        {{ form_widget(form.category, {'attr': {'class': 'form-select shadow-sm rounded'}}) }}
        {{ form_errors(form.category) }}
    </div>

    <!-- Stock -->
    <div class="col-md-6">
        <label class="form-label fw-semibold">Stock</label>
        {{ form_widget(form.stock, {'attr': {'class': 'form-control shadow-sm rounded', 'min': 0}}) }}
        {{ form_errors(form.stock) }}
    </div>

    <!-- Date Added -->
    <div class="col-md-6">
        <label class="form-label fw-semibold">Date Added</label>
        {{ form_widget(form.dateAdded, {'attr': {'class': 'form-control shadow-sm rounded'}}) }}
        {{ form_errors(form.dateAdded) }}
    </div>
</div>

<!-- Submit Button -->
<div class="mt-4">
    <button type="submit" class="btn btn-indigo px-5 py-2 rounded">
        {{ button_label|default('Save') }}
    </button>
</div>
{{ form_end(form) }}

<style>
.form-control, .form-select {
    border-radius: 8px;
    transition: box-shadow 0.3s;
}
.form-control:focus, .form-select:focus {
    box-shadow: 0 0 5px rgba(79, 70, 229, 0.5);
    border-color: #4f46e5;
}
.btn-indigo {
    background-color: #4f46e5;
    color: white;
    border: none;
    transition: background-color 0.3s;
}
.btn-indigo:hover {
    background-color: #4338ca;
}
</style>
