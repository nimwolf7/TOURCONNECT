{% extends 'base.html.twig' %}

{% block title %}Service Details | Tour Connect{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="card shadow-sm border-0" style="background-color: #F5F1E6;">
        <!-- Card Header -->
        <div class="card-header" style="background-color: #0E4A52; color: #fff;">
            <h3 class="mb-0">📄 Service Details</h3>
        </div>

        <!-- Card Body -->
        <div class="card-body p-4">
            <table class="table table-bordered">
                <tbody>
                    <tr>
                        <th>Id</th>
                        <td>{{ service.id }}</td>
                    </tr>
                    <tr>
                        <th>Title</th>
                        <td>{{ service.title }}</td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td>{{ service.description }}</td>
                    </tr>
                    <tr>
                        <th>Price</th>
                        <td>₱{{ service.price|number_format(2) }}</td>
                    </tr>
                    <tr>
                        <th>Category</th>
                        <td>{{ service.category }}</td>
                    </tr>
                    <tr>
                        <th>Stock</th>
                        <td>
                            {% if service.stock > 10 %}
                                <span class="badge bg-success">{{ service.stock }}</span>
                            {% elseif service.stock > 0 %}
                                <span class="badge bg-warning text-dark">{{ service.stock }}</span>
                            {% else %}
                                <span class="badge bg-danger">Out of stock</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th>Date Added</th>
                        <td>{{ service.dateAdded ? service.dateAdded|date('Y-m-d') : '-' }}</td>
                    </tr>
                </tbody>
            </table>

            <!-- Buttons Bottom Right -->
            <div class="d-flex justify-content-end mt-4 gap-2">
                <!-- Back to List Button -->
                <a href="{{ path('app_service_index') }}" class="btn btn-tour-outline px-4 py-2 rounded">
                    ⬅️ Back to List
                </a>

                <!-- Edit Button -->
                <a href="{{ path('app_service_edit', {'id': service.id}) }}" class="btn btn-tour px-4 py-2 rounded">
                    ✏️ Edit
                </a>

                <!-- Delete Form -->
                <form method="post" action="{{ path('app_service_delete', {'id': service.id}) }}" 
                      onsubmit="return confirm('⚠️ Are you sure you want to delete this service?');" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ service.id) }}">
                    <button type="submit" class="btn btn-tour-danger px-4 py-2 rounded">
                        🗑️ Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
/* Tour Connect Buttons */
.btn-tour {
    background-color: #0E4A52;
    color: white;
    border: none;
    font-weight: 500;
}
.btn-tour:hover {
    background-color: #13616c;
}

.btn-tour-outline {
    background-color: transparent;
    color: #0E4A52;
    border: 2px solid #0E4A52;
    font-weight: 500;
}
.btn-tour-outline:hover {
    background-color: #0E4A52;
    color: white;
}

.btn-tour-danger {
    background-color: #dc2626;
    color: white;
    border: none;
    font-weight: 500;
}
.btn-tour-danger:hover {
    background-color: #b91c1c;
}
</style>
{% endblock %}
