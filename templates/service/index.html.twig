{% extends 'base.html.twig' %}

{% block title %}Services{% endblock %}

{% block body %}
<div class="container mt-4">
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">Service Management</h2>
            <p class="text-muted mb-0">Browse and manage all tour packages and services</p>
        </div>
        <a href="{{ path('app_service_new') }}" class="btn btn-tour px-4 py-2">
            <i class="fa-solid fa-plus me-2"></i>Add New Service
        </a>
    </div>

    <!-- Services Grid -->
    <div class="row g-4">
        {% for service in services %}
        <div class="col-lg-4 col-md-6">
            <div class="card service-card shadow-sm border-0 h-100">
                <!-- Service Image -->
                <div class="service-image-wrapper">
                    {% if service.image %}
                        <img src="{{ asset('images/services/' ~ service.image) }}" 
                             class="card-img-top" alt="{{ service.title }}">
                    {% else %}
                        <img src="https://via.placeholder.com/400x250/0E4A52/FFFFFF?text={{ service.title|url_encode }}" 
                             class="card-img-top" alt="{{ service.title }}">
                    {% endif %}
                    <div class="service-badge">
                        {% if service.stock > 10 %}
                            <span class="badge bg-success">In Stock</span>
                        {% elseif service.stock > 0 %}
                            <span class="badge bg-warning text-dark">Limited</span>
                        {% else %}
                            <span class="badge bg-danger">Sold Out</span>
                        {% endif %}
                    </div>
                </div>

                <!-- Service Content -->
                <div class="card-body d-flex flex-column" style="background-color: #F5F1E6;">
                    <!-- Category Badge -->
                    <div class="mb-2">
                        <span class="badge bg-secondary">
                            <i class="fas fa-tag me-1"></i>{{ service.category }}
                        </span>
                    </div>

                    <!-- Title -->
                    <h5 class="card-title fw-bold text-dark mb-2">{{ service.title }}</h5>

                    <!-- Description -->
                    <p class="card-text text-muted mb-3" style="min-height: 60px;">
                        {{ service.description|length > 100 ? service.description|slice(0, 100) ~ '...' : service.description }}
                    </p>

                    <!-- Price and Stock Info -->
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h4 class="text-success mb-0 fw-bold">₱{{ service.price|number_format(2) }}</h4>
                            <small class="text-muted">per person</small>
                        </div>
                        <div class="text-end">
                            <small class="text-muted d-block">Stock</small>
                            <strong class="text-dark">{{ service.stock }}</strong>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="mt-auto">
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_service_show', {'id': service.id}) }}" 
                               class="btn btn-sm btn-tour-outline flex-fill">
                                <i class="fa-solid fa-eye me-1"></i>View
                            </a>
                            <a href="{{ path('app_service_edit', {'id': service.id}) }}" 
                               class="btn btn-sm btn-tour flex-fill">
                                <i class="fa-solid fa-pen-to-square me-1"></i>Edit
                            </a>
                            <button type="button" class="btn btn-sm btn-danger" 
                                    onclick="deleteService({{ service.id }})">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Hidden Delete Form -->
                    <form id="deleteForm{{ service.id }}" method="post" 
                          action="{{ path('app_service_delete', {'id': service.id}) }}" 
                          style="display: none;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ service.id) }}">
                    </form>
                </div>

                <!-- Card Footer with Date -->
                <div class="card-footer bg-white border-top-0 text-center" style="background-color: #F5F1E6 !important;">
                    <small class="text-muted">
                        <i class="far fa-calendar-alt me-1"></i>
                        Added: {{ service.dateAdded ? service.dateAdded|date('M d, Y') : 'N/A' }}
                    </small>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-12">
            <div class="card shadow-sm border-0 text-center py-5" style="background-color: #F5F1E6;">
                <div class="card-body">
                    <i class="fas fa-box-open fa-4x text-muted mb-3"></i>
                    <h4 class="text-muted">No services found</h4>
                    <p class="text-muted mb-3">Start by adding your first service</p>
                    <a href="{{ path('app_service_new') }}" class="btn btn-tour px-4">
                        <i class="fa-solid fa-plus me-2"></i>Add New Service
                    </a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>

<script>
function deleteService(id) {
    if (confirm('⚠️ Are you sure you want to delete this service?')) {
        document.getElementById('deleteForm' + id).submit();
    }
}
</script>

<style>
.service-card {
    transition: all 0.3s ease;
    border-radius: 1rem;
    overflow: hidden;
}

.service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15) !important;
}

.service-image-wrapper {
    position: relative;
    overflow: hidden;
    height: 200px;
}

.service-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.service-card:hover .service-image-wrapper img {
    transform: scale(1.1);
}

.service-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    z-index: 1;
}

.service-badge .badge {
    font-size: 0.75rem;
    padding: 0.5rem 0.75rem;
    font-weight: 600;
}

.btn-tour {
    background-color: #0E4A52;
    color: white;
    border: none;
    font-weight: 500;
    transition: all 0.3s ease;
}

.btn-tour:hover {
    background-color: #13616c;
    color: white;
    transform: translateY(-2px);
}

.btn-tour-outline {
    background-color: transparent;
    color: #0E4A52;
    border: 2px solid #0E4A52;
    font-weight: 500;
    transition: all 0.3s ease;
}

.btn-tour-outline:hover {
    background-color: #0E4A52;
    color: white;
}

.btn-danger {
    background-color: #dc2626;
    border-color: #dc2626;
}

.btn-danger:hover {
    background-color: #b91c1c;
}

.card-footer {
    background-color: #F5F1E6 !important;
}
</style>
{% endblock %}