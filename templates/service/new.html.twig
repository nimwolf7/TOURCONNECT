{% extends 'base.html.twig' %}

{% block title %}New Service | Tour Connect{% endblock %}

{% block body %}
<div class="container mt-5">
    <!-- Flash messages -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <!-- Card Header with Gradient -->
                <div class="card-header text-white py-4" style="background: linear-gradient(135deg, #0E4A52 0%, #13616c 100%);">
                    <div class="d-flex align-items-center">
                        <i class="fas fa-plus-circle fa-2x me-3"></i>
                        <div>
                            <h3 class="mb-0 fw-bold">Create New Service</h3>
                            <small class="text-white-50">Add a new tour package or service</small>
                        </div>
                    </div>
                </div>

                <!-- Card Body -->
                <div class="card-body p-4" style="background-color: #F5F1E6;">
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible fade show">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    {% endfor %}
                    
                    {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}

                    <div class="row g-4">
                        <div class="col-12">
                            {{ form_row(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                        </div>

                        <div class="col-12">
                            {{ form_row(form.title, {'attr': {'class': 'form-control'}}) }}
                        </div>

                        <div class="col-12">
                            {{ form_row(form.description, {'attr': {'class': 'form-control', 'rows': 5}}) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.price, {'attr': {'class': 'form-control'}}) }}
                        </div>

                        <div class="col-md-6">
                            {{ form_row(form.stock, {'attr': {'class': 'form-control'}}) }}
                        </div>

                        <div class="col-12">
                            {{ form_row(form.category, {'attr': {'class': 'form-select'}}) }}
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-end gap-3 mt-5 pt-3 border-top">
                        <a href="{{ path('app_service_index') }}" class="btn btn-tour-outline px-5 py-2">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-tour px-5 py-2">
                            <i class="fas fa-check me-2"></i>Create Service
                        </button>
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
/* Tour Connect Buttons */
.btn-tour {
    background-color: #0E4A52;
    color: white;
    border: none;
    font-weight: 500;
}
.btn-tour:hover {
    background-color: #13616c;
}

.btn-tour-outline {
    background-color: transparent;
    color: #0E4A52;
    border: 2px solid #0E4A52;
    font-weight: 500;
}
.btn-tour-outline:hover {
    background-color: #0E4A52;
    color: white;
}
</style>
{% endblock %}
