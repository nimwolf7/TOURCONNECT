{% set isEdit = button_label is defined and button_label == 'Update' %}
{{ form_start(form, {'attr': {'class': 'booking-form p-4 rounded-4 shadow-sm', 'style': 'background: #F5F1E6'}}) }}
    <h4 class="mb-4 fw-bold text-center" style="color: #0E4A52;">
        {{ isEdit ? '✏️ Update Booking' : '📝 New Booking' }}
    </h4>

    <div class="row g-3">
        {# Render service field with data-price attributes for JS auto-calc #}
        <div class="col-md-6">
            <div class="form-group">
                {{ form_label(form.service, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
                <select name="{{ form.service.vars.full_name }}" class="form-control rounded-3 border-1 shadow-sm" id="booking_service">
                    <option value="">Select a service</option>
                    {% for choice in form.service.vars.choices %}
                        {% set service = choice.data %}
                        <option value="{{ choice.value }}" data-price="{{ service.price }}" {% if choice.value == form.service.vars.value %}selected{% endif %}>{{ choice.label }}</option>
                    {% endfor %}
                </select>
                {{ form_errors(form.service) }}
            </div>
        </div>

        {# Render quantity field #}
        <div class="col-md-6">
            <div class="form-group">
                {{ form_label(form.quantity, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
                {{ form_widget(form.quantity, {'attr': {'class': 'form-control rounded-3 border-1 shadow-sm'}}) }}
                {{ form_errors(form.quantity) }}
            </div>
        </div>

        {# Render status field #}
        <div class="col-md-6">
            <div class="form-group">
                {{ form_label(form.status, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
                {{ form_widget(form.status, {'attr': {'class': 'form-control rounded-3 border-1 shadow-sm'}}) }}
                {{ form_errors(form.status) }}
            </div>
        </div>

        {# Render booking date field #}
        <div class="col-md-6">
            <div class="form-group">
                {{ form_label(form.bookingDate, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
                {{ form_widget(form.bookingDate, {'attr': {'class': 'form-control rounded-3 border-1 shadow-sm'}}) }}
                {{ form_errors(form.bookingDate) }}
            </div>
        </div>

        {# Render total amount field #}
        <div class="col-md-6">
            <div class="form-group">
                {{ form_label(form.totalAmount, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
                {{ form_widget(form.totalAmount, {'attr': {'class': 'form-control rounded-3 border-1 shadow-sm'}}) }}
                {{ form_errors(form.totalAmount) }}
            </div>
        </div>

        {# Render user field #}
        <div class="col-md-6">
            <div class="form-group">
                {{ form_label(form.user, null, {'label_attr': {'class': 'form-label fw-semibold text-dark'}}) }}
                {{ form_widget(form.user, {'attr': {'class': 'form-control rounded-3 border-1 shadow-sm'}}) }}
                {{ form_errors(form.user) }}
            </div>
        </div>
    </div>

    {% set buttonColor = isEdit ? '#EAB308' : '#0E4A52' %}
    {% set buttonText = isEdit ? 'Update Booking' : 'Save Booking' %}

    <div class="text-center mt-4">
        <button class="btn px-4 py-2 text-white rounded-3 fw-semibold" 
                style="background-color: {{ buttonColor }}; transition: 0.3s;">
            {{ buttonText }}
        </button>
    </div>

    {# This tells Symfony that service field is rendered, preventing duplicate #}
    {% do form.service.setRendered() %}

{{ form_end(form) }}

<script>
document.addEventListener('DOMContentLoaded', function() {
    const serviceSelect = document.querySelector('[name$="[service]"]');
    const quantityInput = document.querySelector('[name$="[quantity]"]');
    const totalAmountInput = document.querySelector('[name$="[totalAmount]"]');
    let servicePrices = {};

    // Build a map of service id to price from the select options (if data-price attribute is available)
    if (serviceSelect) {
        Array.from(serviceSelect.options).forEach(opt => {
            if (opt.value && opt.dataset.price) {
                servicePrices[opt.value] = parseFloat(opt.dataset.price);
            }
        });
    }

    function updateTotal() {
        const serviceId = serviceSelect ? serviceSelect.value : null;
        const quantity = quantityInput ? parseInt(quantityInput.value) : 0;
        const price = servicePrices[serviceId] || 0;
        if (totalAmountInput) {
            totalAmountInput.value = (quantity > 0 ? (price * quantity).toFixed(2) : '');
        }
    }

    if (serviceSelect && quantityInput) {
        serviceSelect.addEventListener('change', updateTotal);
        quantityInput.addEventListener('input', updateTotal);
    }
});
</script>